(load "Test.carp")
(use Test)
(load "dynamics.carp")
(use Body)
(use Integrator)
(use Transform)
(use Vector3)

(deftest dynamics-test
  (let [state (Test.State.init 0 0)]
    (do
      ;; 1. Initialization
      (let [b1 (Body.new 10.0 0.5 0.5 1.0)]
        (do
          (set! state (Test.assert-equal &state 10.0 @(Body.mass &b1) "Mass set correctly"))
          (set! state (Test.assert-equal &state 0.1 @(Body.inv-mass &b1) "Inverse mass calculated"))))

      ;; 2. Integration (Velocity to Position)
      (let [t1 (Transform.identity)
            b2 (Body.new 1.0 0.0 0.0 1.0)]
        (do
          (Body.set-velocity! &b2 (Vector3.init 5.0 0.0 0.0))
          (Integrator.step! &t1 &b2 0.01) ;; Small dt to avoid clamping
          (set! state (Test.assert-equal &state 0.05 @(Vector3.x (Transform.position &t1)) "Integration moves transform"))))

      ;; 3. Force Application
      (let [t2 (Transform.identity)
            b3 (Body.new 2.0 0.0 0.0 1.0)]
        (do
          (Body.apply-force! &b3 &(Vector3.init 10.0 0.0 0.0))
          ;; F=10, M=2 -> A=5. V = 0 + 5*0.01 = 0.05. P = 0 + 0.05*0.01 = 0.0005.
          (Integrator.step! &t2 &b3 0.01)
          (set! state (Test.assert-equal &state 0.0005 @(Vector3.x (Transform.position &t2)) "Force affects movement"))
          (set! state (Test.assert-equal &state 0.0 @(Vector3.x (Body.force &b3)) "Force accumulator reset"))))

      ;; 4. Static Body Immunity
      (let [t-stat (Transform.identity)
            b-stat (Body.static)]
        (do
          (Body.apply-force! &b-stat &(Vector3.init 100.0 0.0 0.0))
          (Integrator.step! &t-stat &b-stat 0.01)
          (set! state (Test.assert-equal &state 0.0 @(Vector3.x (Transform.position &t-stat)) "Static bodies do not move"))))
      
      ;; 5. Damping
      (let [t-damp (Transform.identity)
            b-damp (Body.new 1.0 0.0 0.0 0.1)] ;; High damping
        (do
          (Body.set-velocity! &b-damp (Vector3.init 10.0 0.0 0.0))
          (Integrator.step! &t-damp &b-damp 1.0)
          ;; Clamped dt = 0.033. new-v = 10.0 * 0.1^0.033 = 10 * 0.926...
          (set! state (Test.assert-true &state (< @(Vector3.x (Body.velocity &b-damp)) 10.0) "Damping reduces velocity"))))
      
      state)))
