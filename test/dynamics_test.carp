(load "Test.carp")
(use Test)
(load "dynamics.carp")
(use Body)
(use Integrator)
(use Transform)
(use Vector3)

(deftest dynamics-test
  (let [state (Test.State.init 0 0)]
    (let [
          ;; 1. Initialization
          b1 (Body.new 10.0 0.5 0.5)
          s1 (Test.assert-equal &state 10.0 @(Body.mass &b1) "Mass set correctly")
          s2 (Test.assert-equal &s1 0.1 @(Body.inv-mass &b1) "Inverse mass calculated")

          ;; 2. Integration (Velocity to Position)
          t1 (Transform.identity)
          b2 (Body.new 1.0 0.0 0.0)
          _v (Body.set-velocity! &b2 (Vector3.init 5.0 0.0 0.0))
          _s (Integrator.step! &t1 &b2 1.0)
          s3 (Test.assert-equal &s2 5.0 @(Vector3.x (Transform.position &t1)) "Integration moves transform")

          ;; 3. Force Application
          t2 (Transform.identity)
          b3 (Body.new 2.0 0.0 0.0)
          _f (Body.apply-force! &b3 &(Vector3.init 10.0 0.0 0.0))
          ;; F=10, M=2 -> A=5. V = 0 + 5*1.0 = 5. P = 0 + 5*1.0 = 5.
          _s2 (Integrator.step! &t2 &b3 1.0)
          s4 (Test.assert-equal &s3 5.0 @(Vector3.x (Transform.position &t2)) "Force affects movement")
          s5 (Test.assert-equal &s4 0.0 @(Vector3.x (Body.force &b3)) "Force accumulator reset")

          ;; 4. Static Body Immunity
          t-stat (Transform.identity)
          b-stat (Body.static)
          _f2 (Body.apply-force! &b-stat &(Vector3.init 100.0 0.0 0.0))
          _s3 (Integrator.step! &t-stat &b-stat 1.0)
          s6 (Test.assert-equal &s5 0.0 @(Vector3.x (Transform.position &t-stat)) "Static bodies do not move")
          ]
      s6)))
